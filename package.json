{
  "name": "comark",
  "version": "0.1.3",
  "description": "Markdown review companion for Claude Code",
  "type": "module",
  "private": false,
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "bundle": "node scripts/build-server.js",
    "build:web": "cd web && npm run build",
    "build": "npm run build:web && npm run bundle",
    "server": "node server/dist/comark-server.js",
    "server:dev": "node server/index.js",
    "test": "node --test server/test/*.test.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "approx-string-match": "^2.0.0",
    "proper-lockfile": "^4.1.2"
  },
  "bin": {
    "comark-hook": "./bin/comark-hook.js",
    "comark-server": "./server/index.js"
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  }
}
